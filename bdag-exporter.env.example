# bdag-netdata-exporter environment.
# In compose, these are set directly on the exporter service for service
# discovery (pool / node names). Use this file when running the exporter
# outside compose.

POOL_API_URL=http://pool:8080/stats
BDAG_RPC_URL=http://node:38131
BDAG_RPC_USER=test
BDAG_RPC_PASSWORD=test

# Optional fallback labels when RPC does not return them
BDAG_NETWORK=mainnet
BDAG_NODE_VERSION=unknown
