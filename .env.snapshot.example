# Env file for docker-compose.snapshot-node.yml (dedicated export node).
# Usage:
#   docker compose -p snapshot-node -f docker-compose.snapshot-node.yml --env-file .env.snapshot up -d

BUILD_CONTEXT=.
DOCKERFILE=dockerfile
DOCKER_PLATFORM=linux/amd64

# Bootstrap at image build time. Use marker for empty chain:
#   SNAPSHOT_PATH=docker/no-snapshot.marker
SNAPSHOT_PATH=docker/no-snapshot.marker

# Host ports must differ from the mining stack if both run on one machine.
P2P_PORT=9150
BDAG_RPC_PORT=48131
EVM_HTTP_PORT=28545
EVM_WS_PORT=28546
NODE_METRICS_PORT=16060

# Match rpcuser / rpcpass in node.snapshot.conf if you call RPC from the host.
NODE_RPC_USER=test
NODE_RPC_PASS=test

# Serve Fast Artifact Sync V2 and try V2 bootstrap on first empty start.
SNAPSHOT_NODE_ARGS_APPEND=--fastartifactsync
SNAPSHOT_BDAG_FASTSNAP_ENABLED=1
SNAPSHOT_BDAG_FASTSNAP_REQUIRED=0
SNAPSHOT_BDAG_FASTSNAP_AUTO_MAX_PEERS=3
SNAPSHOT_BDAG_FASTSNAP_TIMEOUT=300s
SNAPSHOT_BDAG_FASTSNAP_PARALLELISM=8
SNAPSHOT_BDAG_FASTSNAP_RETRIES=5
SNAPSHOT_BDAG_FASTSNAP_RETRY_DELAY=10s

# Hot snapshot refresher defaults when scripts/hotsnap-refresh.sh is used.
BDAG_HOTSNAP_ENABLED=1
BDAG_HOTSNAP_INTERVAL=1h
BDAG_HOTSNAP_INITIAL_DELAY=20m
BDAG_HOTSNAP_STOP_TIMEOUT=60
BDAG_HOTSNAP_DATADIR=/var/lib/bdagStack/node/mainnet
BDAG_HOTSNAP_ARCHIVE=/var/lib/bdagStack/node/mainnet/snapshot.bdsnap
