# BlockDAG node configuration for the Docker Compose stack.

# P2P listen
listen=0.0.0.0
port=8150
p2ptcpport=8150
# Leave externalip unset by default. Set BDAG_P2P_ADVERTISE_IP only when this
# host has a reachable public/static address or correct port forwarding.

# BDAG RPC listen
rpclisten=0.0.0.0:38131

# EVM RPC listen
evm.http.addr=0.0.0.0
evm.http.port=18545
evm.ws.addr=0.0.0.0
evm.ws.port=18546


# Bootstrap peers (mainnet seed nodes). Add one addpeer=... line per complete
# BDAG P2P multiaddr. Keep only public peers that are currently reachable.
addpeer=/ip4/3.126.64.13/tcp/8152/p2p/16Uiu2HAmEFxRaBbbf3sRi43CCvMk5Y6zPkuGY9s4uRK2FKJVJkqo
