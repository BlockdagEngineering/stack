# BlockDAG node configuration for the Docker Compose stack.

# P2P listen
listen=0.0.0.0
port=8150
p2ptcpport=8150
# Leave externalip unset by default. Set BDAG_P2P_ADVERTISE_IP only when this
# host has a reachable public/static address or correct port forwarding.

# BDAG RPC listen
rpclisten=0.0.0.0:38131

# EVM RPC listen
evm.http.addr=0.0.0.0
evm.http.port=18545
evm.ws.addr=0.0.0.0
evm.ws.port=18546


# Bootstrap peers (mainnet seed nodes). Add one addpeer=... line per complete
# BDAG P2P multiaddr. Keep only public peers that are currently reachable.
#RPC node:
addpeer=/ip4/63.182.36.180/tcp/8150/p2p/16Uiu2HAmP8HsTF9ks8JjFamzT9JBZb3ymSiCJ8rkzXBZqYj4yKtP
#Public pool:
addpeer=/ip4/16.28.133.168/tcp/8150/p2p/16Uiu2HAmMzJVJC8jnU8EkFgCDovALykFA7mNJS688niD46Bk8Vww

addpeer=/ip4/154.70.222.46/tcp/8150/p2p/16Uiu2HAmFnT4RgMchwebsSE6qz45vFjD3F1wzni4M3KcgEzNxncD
addpeer=/ip4/172.31.42.61/tcp/8150/p2p/16Uiu2HAmGxNiCJCkyuwLTKmNq1qX2yqoRmLtoDMgHwwiVZzLUyiq

# Peer limit
maxpeers=350
cache=2048
cache.database=70

# RPC auth. Must match NODE_RPC_USER / NODE_RPC_PASS in .env.
rpcuser=bdag_mainnet_rpc
rpcpass=change-me-mainnet-rpc-password

# Storage paths
datadir=/var/lib/bdagStack/node
logdir=/var/log/bdagStack

# Native metrics endpoint
metrics=true
profile=0.0.0.0:1234

# Keep empty unless node mining is intentionally enabled.
miningaddr=

modules=Blockdag
modules=miner

evm.http.api=eth,net,web3,txpool,debug
http.readtimeout=45s
http.writetimeout=45s
http.idletimeout=45s
evmenv="--rpc.allow-unprotected-txs --metrics --cache 2048 --maxpeers 50 --port 30303"
rpcmaxclients=64
rpcmaxclientsperhost=16
rpcmaxconcurrentreqs=500
rpcrequesttimeout=60s
http.ratelimit=1800
http.rateburst=3200
