# Pool-Stack Docker Compose — CPU stack (miner image + profile).
#
# Copy to `.env`:
#   cp .env.cpu.example .env    # tarball with dockerfile-cpu-release, OR git clone (adjust block below).
#
# - **cpu-v* tarball:** keep the "Release (prebuilt bin)" settings (BUILD_CONTEXT=.).
# - **Git clone (dockerfile-dev):** switch to "Git dev" in the boxed section below.

# ============================================================================
# Git dev — local compile (docker-compose from this repo beside ../blockdag-corechain)
# Replace the Release block defaults with these three lines when building images from source:
#   BUILD_CONTEXT=..
#   DOCKERFILE=pool-stack-docker/dockerfile-dev
#   SNAPSHOT_PATH=
# Leave COMPOSE_PROFILES=miner to include the cpu-miner image and service profile.
# ============================================================================

# ----------------------------------------------------------------------------
# Release (prebuilt ./bin — matches cpu-v* tarball)
# ---------------------------------------------------------------------------
BUILD_CONTEXT=.
DOCKERFILE=dockerfile-cpu-release
# Default marker skips snap import unless you replace with a real .bdsnap path.
SNAPSHOT_PATH=docker/no-snapshot.marker

# Not used by docker compose build from the tarball (offline).
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Always include the CPU miner service (same as `docker compose --profile miner`)
# ---------------------------------------------------------------------------
COMPOSE_PROFILES=miner

# ---------------------------------------------------------------------------
# Network / port mapping
# ---------------------------------------------------------------------------
NETWORK=mainnet
P2P_PORT=8150
BDAG_RPC_PORT=38131
EVM_HTTP_PORT=18545
EVM_WS_PORT=18546
NODE_METRICS_PORT=6060
POOL_BIND_PORT=3334
POOL_API_PORT=8080

# Optional pre-start P2P snapshot bootstrap. When BDAG_FASTSNAP_PEERS is set
# and the node datadir is empty, the node image downloads a trusted peer
# snapshot first, imports it, then normal FastSync catches the remaining tail.
BDAG_FASTSNAP_PEERS=
BDAG_FASTSNAP_MIN_TIP=0
BDAG_FASTSNAP_TIMEOUT=90s

# FastSync candidate order for new/empty nodes and startup peers. Entries must
# be complete multiaddrs with peer IDs. FastSnap receives all candidates at
# once and prefers lower-latency libp2p peers automatically.
BDAG_FASTSYNC_PEER_ORDERING=1
BDAG_FASTSYNC_APPEND_ADDPEERS=1
BDAG_FASTSYNC_PUBLIC_PEERS=
BDAG_FASTSYNC_PEERS=
BDAG_FASTSYNC_PREPROCESS_WORKERS=1

# ---------------------------------------------------------------------------
# Node RPC auth (must match node.conf rpcuser / rpcpass after you copy from node.conf.example)
# ---------------------------------------------------------------------------
NODE_RPC_USER=test
NODE_RPC_PASS=test

# ---------------------------------------------------------------------------
# Postgres (used by the pool service via PG_URL)
# ---------------------------------------------------------------------------
POSTGRES_USER=bdag_pool
POSTGRES_DB=bdagpool
POSTGRES_PASSWORD=change_me_to_a_strong_secret

# ---------------------------------------------------------------------------
# Mining pool — passed into `pool` container (asic-pool env)
# ---------------------------------------------------------------------------
POOL_BIND_ADDR=0.0.0.0:3334
PPLNS_N_WORK=1000
POOL_FEE_PERCENTAGE=1.0
POOL_BLOCK_MATURITY=10
POOL_PAYOUT_MATURITY=4096

# ---------------------------------------------------------------------------
# CPU miner — COMPOSE_PROFILES=miner above; set payout / worker identity here
# ---------------------------------------------------------------------------
MINING_POOL_ADDRESS=0x0000000000000000000000000000000000000000
MINER_POOL_PASS=x
MINER_WORKERS=1
