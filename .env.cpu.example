# Pool-Stack Docker Compose — CPU release tarball (cpu-v* tags).
# Copy to .env:  cp .env.cpu.example .env
#
# This file matches what GitHub Actions ships in pool-stack-docker-<cpu-v*>.tar.gz:
# - dockerfile-cpu-release (includes blockdag-node, pool, cpu-miner, exporter)
# - COMPOSE_PROFILES=miner so `docker compose up` starts the optional miner service
#
# The pool-only tarball (pool-v*) uses dockerfile-pool-release and has no miner
# image target; do not use COMPOSE_PROFILES=miner there.

# ---------------------------------------------------------------------------
# Image build = copy ./bin only (no git clone in Dockerfiles)
# ---------------------------------------------------------------------------
BUILD_CONTEXT=.
DOCKERFILE=dockerfile-cpu-release
# Default marker skips snap import unless you replace with a real .bdsnap path.
SNAPSHOT_PATH=docker/no-snapshot.marker

# Not used by docker compose build from the tarball (offline).
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Always include the CPU miner service (same as `docker compose --profile miner`)
# ---------------------------------------------------------------------------
COMPOSE_PROFILES=miner

# ---------------------------------------------------------------------------
# Network / port mapping
# ---------------------------------------------------------------------------
NETWORK=mainnet
P2P_PORT=8150
BDAG_RPC_PORT=38131
EVM_HTTP_PORT=18545
EVM_WS_PORT=18546
NODE_METRICS_PORT=6060
POOL_BIND_PORT=3334
POOL_API_PORT=8080
EXPORTER_PORT=9198
NETDATA_PORT=19999

# ---------------------------------------------------------------------------
# Node RPC auth (must match node.conf rpcuser / rpcpass after you copy from node.conf.example)
# ---------------------------------------------------------------------------
NODE_RPC_USER=test
NODE_RPC_PASS=test

# ---------------------------------------------------------------------------
# Postgres (used by the pool service via PG_URL)
# ---------------------------------------------------------------------------
POSTGRES_USER=bdag_pool
POSTGRES_DB=bdagpool
POSTGRES_PASSWORD=change_me_to_a_strong_secret

# ---------------------------------------------------------------------------
# Mining pool — passed into `pool` container (see .env.example)
# ---------------------------------------------------------------------------
POOL_BIND_ADDR=0.0.0.0:3334
PPLNS_N_WORK=1000
POOL_FEE_PERCENTAGE=1.0
POOL_BLOCK_MATURITY=10
POOL_PAYOUT_MATURITY=4096

# ---------------------------------------------------------------------------
# CPU miner — COMPOSE_PROFILES=miner above; set payout / worker identity here
# ---------------------------------------------------------------------------
MINER_POOL_USER=0x0000000000000000000000000000000000000000
MINER_POOL_PASS=x
MINER_WORKERS=1
