# Pool-Stack Docker Compose — CPU release tarball (cpu-v* tags).
# Copy to .env:  cp .env.cpu.example .env
#
# This file matches what GitHub Actions ships in pool-stack-docker-<cpu-v*>.tar.gz:
# - dockerfile-cpu-release (includes blockdag-node, pool, cpu-miner, exporter)
# - COMPOSE_PROFILES=miner so `docker compose up` starts the optional miner service
#
# The pool-only tarball (pool-v*) uses dockerfile-pool-release and has no miner
# image target; do not use COMPOSE_PROFILES=miner there.

# ---------------------------------------------------------------------------
# Build mode (release Dockerfile clones private repos at build time)
# ---------------------------------------------------------------------------
DEV=false
# Build context is this directory when using an unpacked release tarball.
BUILD_CONTEXT=.
DOCKERFILE=dockerfile-cpu-release

# Required: PAT with Contents: Read on blockdag-corechain, asic-pool, pool-stack,
# and cpu-miner (cpu release only).
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Always include the CPU miner service (same as `docker compose --profile miner`)
# ---------------------------------------------------------------------------
COMPOSE_PROFILES=miner

# ---------------------------------------------------------------------------
# Optional snapshot import when building the node image (local .bdsnap only).
# Path is relative to BUILD_CONTEXT (this directory for release tarballs).
# ---------------------------------------------------------------------------
SNAPSHOT_PATH=

# ---------------------------------------------------------------------------
# Network / port mapping
# ---------------------------------------------------------------------------
NETWORK=mainnet
P2P_PORT=8150
BDAG_RPC_PORT=38131
EVM_HTTP_PORT=18545
EVM_WS_PORT=18546
NODE_METRICS_PORT=6060
POOL_BIND_PORT=3334
POOL_API_PORT=8080
EXPORTER_PORT=9198
NETDATA_PORT=19999

# ---------------------------------------------------------------------------
# Node RPC auth (must match config/node.conf.example rpcuser / rpcpass)
# ---------------------------------------------------------------------------
NODE_RPC_USER=test
NODE_RPC_PASS=test

# ---------------------------------------------------------------------------
# Postgres (used by the pool service via PG_URL)
# ---------------------------------------------------------------------------
POSTGRES_USER=bdag_pool
POSTGRES_DB=bdagpool
POSTGRES_PASSWORD=change_me_to_a_strong_secret

# ---------------------------------------------------------------------------
# CPU miner — active because COMPOSE_PROFILES=miner; edit config/miner.env
# (copy from config/miner.env.example) for POOL_URL / POOL_USER / WORKERS.
# ---------------------------------------------------------------------------
