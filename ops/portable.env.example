# Copy this to ops/runtime/ops.env on a new pool host and edit it there.
# The installer writes the path values automatically, but this file documents
# the knobs that make the dashboard portable across pool stacks.

# Filesystem locations.
# BDAG_PROJECT_ROOT=/opt/blockdag-asic-pool
# BDAG_RUNTIME_DIR=/var/lib/bdag-dashboard
# BDAG_POOL_ENV_FILE=/opt/blockdag-asic-pool/.env
# BDAG_DATA_DIR=/opt/blockdag-asic-pool/data

# Dashboard listener. Keep this on 127.0.0.1 and use SSH forwarding unless the
# host is on a trusted private management network.
BDAG_DASHBOARD_BIND=127.0.0.1
BDAG_DASHBOARD_PORT=8088
BDAG_DASHBOARD_REQUIRE_TOKEN=auto
BDAG_DASHBOARD_EARNINGS_SAMPLER_INTERVAL_SECONDS=60
BDAG_DASHBOARD_GLOBAL_SAMPLER_INTERVAL_SECONDS=60
BDAG_WATCHDOG_EARNINGS_SNAPSHOT_INTERVAL_SECONDS=60
BDAG_STATUS_SAMPLER_EARNINGS_SNAPSHOT_INTERVAL_SECONDS=60

# Pool identity and miner defaults. These can override values in asic-pool/.env.
# BDAG_MINING_ADDRESS=0x0000000000000000000000000000000000000000
# BDAG_POOL_PORT=3334
# BDAG_POOL_HOST=192.168.1.10
# BDAG_POOL_URL=stratum+tcp://192.168.1.10:3334
# BDAG_MINER_SCAN_TARGET=192.168.1.0/24
# BDAG_MINER_POOL_PASSWORD=1234

# Docker/container mapping. Change these if another pool uses different names.
BDAG_POOL_CONTAINER=pool
BDAG_POOL_CONTAINERS=pool
BDAG_POOL_DB_CONTAINER=postgres
BDAG_POOL_DB_USER=test
BDAG_POOL_DB_NAME=pool
BDAG_NODE_SERVICES=node
BDAG_STACK_SERVICES=postgres,node,pool

# If the dashboard runs away from the pool host, use Docker's SSH transport.
# Example: DOCKER_HOST=ssh://pool-admin@192.168.1.10
# DOCKER_HOST=

# If Docker inspect cannot discover node RPC URLs, set them explicitly.
# Format is name=url,name=url. Public RPC/explorer checks are optional.
# BDAG_NODE_RPC_URLS=node=http://192.168.1.10:38131
NODE_RPC_URLS=http://node:38131
POOL_SUBMIT_RPC_URLS=
# BDAG_PUBLIC_RPC_URLS=bdagscan=https://rpc.bdagscan.com,engineering=https://rpc.blockdag.engineering
# BDAG_EXPLORER_API_URLS=bdagscan=https://bdagscan.com
# BDAG_BLOCKSCOUT_V2_URLS=engineering=https://explorer.blockdag.engineering

# Repair commands. Use wrapper scripts if your target stack is not controlled by
# the Makefile in this repository.
# BDAG_START_COMMAND=make up
# BDAG_STOP_COMMAND=make down
# BDAG_CLEAN_RESTORE_COMMAND=
# BDAG_RESTORE_NODE1_COMMAND=make restore-node1-snapshot

# CoinMarketCap. The dashboard can scrape the public page, but an API key is
# preferred if you have one.
# CMC_PRO_API_KEY=
BDAG_CMC_ID=31162
BDAG_CMC_SLUG=blockdag
