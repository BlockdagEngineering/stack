# Copy to .env before staged run if local defaults need changing.

COMPOSE_PROJECT_NAME=bdag-observability

GRAFANA_PORT=3001
PROMETHEUS_PORT=9091
ALERTMANAGER_PORT=9094
LOKI_PORT=3101
# Keep this at 127.0.0.1 for local-only access, or set it to the ZeroTier IP.
OBS_BIND_ADDR=127.0.0.1

BDAG_DASHBOARD_BASE_URL=http://host.docker.internal:8088
BDAG_POOL_ENDPOINT=192.168.1.120:3334
# Replace with a dedicated read-only monitoring account before staged run.
# Leave unset to avoid committing placeholder database credentials.
# BDAG_POSTGRES_DSN=postgresql://monitor_readonly:replace-me@host.docker.internal:5432/pool?sslmode=disable

GRAFANA_ADMIN_USER=admin
# Replace in a non-committed .env before staged run.
GRAFANA_ADMIN_PASSWORD=replace-with-local-password
