    {
      "id": 12,
      "type": "table",
      "title": "Freshness Detail",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 34,
        "w": 24,
        "h": 9
      },
      "targets": [
        {
          "expr": "sort_desc(bdag_miner_last_share_age_seconds)",
          "legendFormat": "last share age",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sort_desc(bdag_miner_last_submit_age_seconds)",
          "legendFormat": "last submit age",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sort_desc(bdag_miner_connected)",
          "legendFormat": "connected",
          "refId": "C",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sort_desc(bdag_miner_up)",
          "legendFormat": "ok",
          "refId": "D",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "service": true,
              "ip": true,
              "mac": true
            },
            "renameByName": {
              "Value": "Value",
              "miner": "Miner",
              "node": "Node",
              "pool": "Pool"
            }
          }
        }
      ]
    },
    {
      "id": 13,
      "type": "logs",
      "title": "Freshness And Repair Events",
      "datasource": {
        "type": "loki",
        "uid": "bdag-loki"
      },
      "gridPos": {
        "x": 0,
        "y": 43,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "expr": "{job=~\"docker|bdag-runtime\"} |~ \"(share_stall|job_stall|miner_down|degraded|repair|disconnect|read error|connection reset)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
