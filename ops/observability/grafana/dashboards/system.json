{
  "uid": "bdag-system",
  "title": "BDAG Host And Containers",
  "tags": [
    "blockdag",
    "mining",
    "provisioned"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m",
      "15m"
    ],
    "time_options": [
      "1h",
      "6h",
      "12h",
      "24h",
      "3d",
      "7d",
      "30d"
    ]
  },
  "editable": false,
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": [
    {
      "title": "Operator Cockpit",
      "url": "/d/bdag-operator-cockpit/bdag-operator-cockpit",
      "targetBlank": false,
      "type": "link"
    },
    {
      "title": "Accepted Work Share",
      "url": "/d/bdag-work-share/bdag-accepted-work-share",
      "targetBlank": false,
      "type": "link"
    },
    {
      "title": "Miner Freshness",
      "url": "/d/bdag-miner-freshness/bdag-miner-freshness",
      "targetBlank": false,
      "type": "link"
    },
    {
      "title": "Observed Peer IPs",
      "url": "/d/bdag-observed-peers/bdag-observed-peer-ips",
      "targetBlank": false,
      "type": "link"
    },
    {
      "title": "Template Fan-In",
      "url": "/d/bdag-template-fan-in/bdag-template-fan-in",
      "targetBlank": false,
      "type": "link"
    },
    {
      "title": "Old Repair Dashboard",
      "url": "http://127.0.0.1:8088",
      "targetBlank": true,
      "type": "link"
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CPU Load 1m",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Disk Free %",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "100 * node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Postgres Exporter Up",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{job=\"postgres-exporter\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CPU Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "maxDataPoints": 1200,
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval])) * 100)",
          "legendFormat": "cpu used",
          "refId": "A",
          "interval": "$__interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory Available",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 8,
        "y": 9
      },
      "maxDataPoints": 1200,
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "available",
          "refId": "A",
          "interval": "$__interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Container CPU",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 16,
        "y": 9
      },
      "maxDataPoints": 1200,
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"asic-pool|bdag-miner-node-[0-9]+|pool-db|rpc-failover\"}[$__rate_interval])",
          "legendFormat": "{{name}}",
          "refId": "A",
          "interval": "$__interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ]
}
