    "time_options": [
      "1h",
      "6h",
      "12h",
      "24h",
      "3d",
      "7d",
      "30d"
    ]
  },
  "editable": false,
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": [
    {
      "title": "Operator Cockpit",
