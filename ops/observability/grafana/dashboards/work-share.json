    {
      "id": 12,
      "type": "table",
      "title": "Work Share Detail",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 34,
        "w": 24,
        "h": 9
      },
      "targets": [
        {
          "expr": "sort_desc(bdag_miner_work_percent)",
          "legendFormat": "work %",
          "refId": "A",
          "instant": true,
          "format": "table"
