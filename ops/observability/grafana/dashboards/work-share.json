    {
      "id": 9,
      "type": "timeseries",
      "title": "Accepted Work Share Over Time",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 10
      },
      "maxDataPoints": 1200,
      "targets": [
        {
          "expr": "bdag_miner_work_percent",
          "legendFormat": "{{miner}}",
          "refId": "A",
          "interval": "$__interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never",
            "spanNulls": true
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
