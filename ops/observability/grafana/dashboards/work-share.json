        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "service": true,
              "ip": true,
              "mac": true
            },
            "renameByName": {
              "Value": "Value",
              "miner": "Miner",
              "node": "Node",
              "pool": "Pool"
            }
          }
        }
      ]
    }
