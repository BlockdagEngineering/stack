{
  "uid": "bdag-nodes",
  "title": "BDAG Nodes",
  "tags": [
    "blockdag",
    "mining",
    "provisioned"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m",
      "15m"
    ],
    "time_options": [
      "1h",
      "6h",
      "12h",
      "24h",
      "3d",
      "7d",
      "30d"
    ]
  },
  "editable": false,
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": [
    {
      "title": "Operator Cockpit",
      "url": "/d/bdag-operator-cockpit/bdag-operator-cockpit",
      "targetBlank": false,
      "type": "link"
    },
    {
      "title": "Accepted Work Share",
      "url": "/d/bdag-work-share/bdag-accepted-work-share",
      "targetBlank": false,
      "type": "link"
    },
    {
      "title": "Miner Freshness",
      "url": "/d/bdag-miner-freshness/bdag-miner-freshness",
      "targetBlank": false,
      "type": "link"
    },
    {
      "title": "Observed Peer IPs",
      "url": "/d/bdag-observed-peers/bdag-observed-peer-ips",
      "targetBlank": false,
      "type": "link"
    },
    {
      "title": "Template Fan-In",
      "url": "/d/bdag-template-fan-in/bdag-template-fan-in",
      "targetBlank": false,
      "type": "link"
    },
    {
      "title": "Old Repair Dashboard",
      "url": "http://127.0.0.1:8088",
      "targetBlank": true,
      "type": "link"
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Block Lag",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "bdag_node_block_lag",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Recent Importers",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "bdag_node_recent_importers",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Remaining Blocks",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "bdag_sync_remaining_blocks",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latest Block",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "maxDataPoints": 1200,
      "targets": [
        {
          "expr": "bdag_node_latest_block",
          "legendFormat": "{{node}}",
          "refId": "A",
          "interval": "$__interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Import Age",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 8,
        "y": 9
      },
      "maxDataPoints": 1200,
      "targets": [
        {
          "expr": "bdag_node_last_import_age_seconds",
          "legendFormat": "{{node}}",
          "refId": "A",
          "interval": "$__interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Native Node Height",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 16,
        "y": 9
      },
      "maxDataPoints": 1200,
      "targets": [
        {
          "expr": "Blockdag_mainheight{job=\"bdag-native-node\"}",
          "legendFormat": "{{node}}",
          "refId": "A",
          "interval": "$__interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Native Tips And Unsequenced",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "maxDataPoints": 1200,
      "targets": [
        {
          "expr": "Blockdag_tips_total{job=\"bdag-native-node\"}",
          "legendFormat": "tips {{node}}",
          "refId": "A",
          "interval": "$__interval"
        },
        {
          "expr": "Blockdag_unsequenced{job=\"bdag-native-node\"}",
          "legendFormat": "unsequenced {{node}}",
          "refId": "B",
          "interval": "$__interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Template Errors",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 8,
        "y": 18
      },
      "maxDataPoints": 1200,
      "targets": [
        {
          "expr": "bdag_node_template_errors_recent",
          "legendFormat": "{{node}}",
          "refId": "A",
          "interval": "$__interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "P2P Stream Errors",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 16,
        "y": 18
      },
      "maxDataPoints": 1200,
      "targets": [
        {
          "expr": "bdag_node_p2p_stream_errors_recent",
          "legendFormat": "{{node}}",
          "refId": "A",
          "interval": "$__interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ]
}
