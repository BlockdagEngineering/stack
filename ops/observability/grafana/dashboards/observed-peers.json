              "Value": "Value",
              "miner": "Miner",
              "node": "Node",
              "pool": "Pool"
            }
          }
        }
      ]
    },
    {
      "id": 13,
      "type": "logs",
      "title": "P2P And Peer-Related Logs",
      "datasource": {
        "type": "loki",
        "uid": "bdag-loki"
      },
      "gridPos": {
        "x": 0,
        "y": 41,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "expr": "{job=\"docker\",container=~\"bdag-miner-node-[0-9]+\"} |~ \"(peer|P2P|stream|sync|import)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
