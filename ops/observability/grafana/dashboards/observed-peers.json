    {
      "id": 11,
      "type": "timeseries",
      "title": "Peer Count And Node Health",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 19,
        "w": 12,
        "h": 10
      },
      "maxDataPoints": 1200,
      "targets": [
        {
          "expr": "bdag_peer_ip_count",
          "legendFormat": "peer IPs",
          "refId": "A",
          "interval": "$__interval"
        },
        {
          "expr": "bdag_peer_geo_ip_count",
          "legendFormat": "geolocated peers",
          "refId": "B",
          "interval": "$__interval"
        },
        {
          "expr": "bdag_node_recent_importers",
          "legendFormat": "recent importing nodes",
          "refId": "C",
          "interval": "$__interval"
        },
        {
          "expr": "bdag_node_block_lag",
          "legendFormat": "node block lag",
          "refId": "D",
          "interval": "$__interval"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 12,
      "type": "table",
      "title": "Observed Peer IP Detail",
      "datasource": {
        "type": "prometheus",
