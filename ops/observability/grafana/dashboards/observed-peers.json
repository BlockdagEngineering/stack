    {
      "id": 7,
      "type": "table",
      "title": "Best Guess Location",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 5
      },
      "targets": [
        {
          "expr": "bdag_peer_location_best_guess",
          "legendFormat": "best guess",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "service": true,
              "ip": true,
              "mac": true
            },
            "renameByName": {
              "Value": "Value",
              "miner": "Miner",
              "node": "Node",
              "pool": "Pool"
            }
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Peer Countries",
      "datasource": {
        "type": "prometheus",
        "uid": "bdag-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 10
      },
      "targets": [
        {
          "expr": "sort_desc(bdag_peer_location_share_percent{level=\"country\"})",
          "legendFormat": "{{label}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "palette-classic"
          },
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 18,
        "minVizWidth": 0,
        "namePlacement": "left",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      }
    },
