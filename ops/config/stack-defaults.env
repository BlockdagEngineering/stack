# Canonical stack-owned deployment defaults.
#
# This file is the source of truth for non-secret, non-site-specific defaults
# that are projected into compose, installers, runtime env examples, dashboard
# helpers, watchdogs, and release validation. Do not put passwords, private
# keys, wallet secrets, host IPs, local paths, or operator-specific overrides in
# this file.

# Compose/service topology.
BDAG_POOL_CONTAINER=pool
BDAG_POOL_CONTAINERS=pool
BDAG_POOL_DB_CONTAINER=postgres
BDAG_POOL_DB_USER=bdag_pool
BDAG_POOL_DB_NAME=bdagpool
BDAG_NODE_MODE=single
BDAG_NODE_SERVICES=node
BDAG_STACK_SERVICES=postgres,node,pool
BDAG_AUTOMATION_HIGH_RISK_CONTROLLER=watchdog
BDAG_NODE_START_GUARD_ENABLED=1
BDAG_POOL_START_GUARD_ENABLED=1
BDAG_POOL_START_LEASE_MAX_AGE_SECONDS=120

# Node and sync defaults.
NODE_DATA_DIR=./data/node
SYNC_SOURCE_NODE=0
BDAG_CHAIN_PEERSTORE_PEER_EXTRACTION_ENABLED=1
BDAG_CHAIN_PEERSTORE_LOG_TAIL=8000
BDAG_CHAIN_PEERSTORE_SERVICE_PORTS=8150,8151,8152,8153,8154
BDAG_NO_FASTSYNC_SERVE=auto
BDAG_NODE_DEBUG_LEVEL=warn
BDAG_NODE_NO_FILE_LOGGING=1
BDAG_NODE_MINING_NO_PENDING_TX=1
BDAG_EPOCH_RECOVERY_AUTO_REWIND=1
BDAG_FASTARTIFACTSYNC_ENABLED=1
BDAG_FASTSYNC_RANGE_BLOCKS=1024
BDAG_FASTSYNC_PREPROCESS_WORKERS=1
BDAG_FASTSNAP_SEED_TIMER_ENABLED=0
BDAG_FASTSNAP_DIRECTORY_MODE=1
BDAG_FASTSYNC_ARTIFACT_DIRECTORY=
BDAG_FASTSYNC_ARTIFACT_MANIFEST=
BDAG_SYNC_COORDINATOR_ACCELERATE_FASTSYNC=1
BDAG_SYNC_COORDINATOR_FAST_RESTART_COOLDOWN_SECONDS=900
BDAG_SYNC_COORDINATOR_RESTART_ON_STALE_IMPORT=1
BDAG_CATCHUP_PAUSE_ENABLED=1
BDAG_CATCHUP_PAUSE_THRESHOLD_BLOCKS=300
BDAG_CATCHUP_IO_PRESSURE_PAUSE_ENABLED=1
BDAG_CATCHUP_IO_PRESSURE_MIN_LAG_BLOCKS=25
BDAG_CATCHUP_IOWAIT_WARN_PERCENT=15
BDAG_CATCHUP_IO_SOME_AVG10_WARN=20.0
BDAG_CATCHUP_IO_FULL_AVG10_WARN=10.0
BDAG_CATCHUP_NODE_RECREATE_ENABLED=1
BDAG_CATCHUP_NODE_CACHE_MB=2048
BDAG_CATCHUP_NODE_CACHE_MIN_MB=1024
BDAG_CATCHUP_NODE_CACHE_MEMORY_PERCENT=20
BDAG_CATCHUP_NODE_CACHE_PRESSURE_RESTORE_ENABLED=1
BDAG_CATCHUP_NODE_CACHE_MIN_AVAILABLE_MB=1024
BDAG_CATCHUP_NODE_CACHE_SWAP_USED_RESTORE_MB=64
BDAG_INSTALL_AUTOTUNE_CACHE=1
BDAG_INSTALL_MEMORY_PROFILE=auto
BDAG_INSTALL_DETECTED_MEMORY_MB=
BDAG_NODE_CHAIN_RPC_TIMEOUT=8.0
BDAG_NODE_CHAIN_RPC_RETRIES=2
BDAG_POOL_RPC_REFUSED_WARN_SECONDS=120

# Chain-state repair and artifact safety.
BDAG_CHAIN_STATE_SELF_HEAL_ENABLED=1
BDAG_MINING_IMPERATIVE_CHAIN_STATE_RESTORE_ENABLED=1
BDAG_CHAIN_STATE_STALLED_IMPORT_RESTORE_ENABLED=1
BDAG_CHAIN_STATE_STALLED_IMPORT_RESTORE_SECONDS=900
BDAG_CHAIN_STATE_STALLED_IMPORT_RESTORE_PEER_AHEAD_BLOCKS=1000
BDAG_CHAIN_STATE_STALLED_IMPORT_RESTORE_GAP_GROWTH_BLOCKS=60
BDAG_EVM_REFERENCE_GAP_STALL_RESTORE_ENABLED=1
BDAG_EVM_REFERENCE_GAP_STALL_RESTORE_SECONDS=900
BDAG_EVM_REFERENCE_GAP_STALL_MIN_LAG_BLOCKS=1000
BDAG_EVM_REFERENCE_GAP_STALL_MIN_IMPROVEMENT_BLOCKS=60
BDAG_CHAIN_STATE_REUSE_EXISTING_SNAPSHOT=1
BDAG_FAST_CATCHUP_ARTIFACT_MODE=auto
BDAG_FAST_CATCHUP_ARTIFACT_RETRY_SECONDS=300
BDAG_FAST_CATCHUP_ARTIFACT_MIN_BEHIND_BLOCKS=1000
BDAG_FAST_CATCHUP_ARTIFACT_MIN_GAIN_BLOCKS=1000
BDAG_FAST_CATCHUP_ARTIFACT_TRUST_ON_FIRST_SIGNED=1
BDAG_FAST_CATCHUP_ALLOW_UNSIGNED_ARTIFACTS=0
BDAG_FAST_CATCHUP_ARTIFACT_TIMEOUT=21600s
BDAG_ENABLE_AUTOMATIC_CLEAN_RESTORE=0
BDAG_BOOT_REPAIR_DIRTY_POLICY=start
BDAG_BOOT_REPAIR_CRITICAL_POLICY=restart

# Dashboard/status/global-production sampling.
BDAG_SHARED_STATUS_CACHE_ENABLED=1
