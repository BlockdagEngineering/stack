[Unit]
Description=BlockDAG Fast Artifact Sync V2 hot seed sidecar
After=default.target

[Service]
Type=oneshot
Environment=BDAG_FASTARTIFACT_SIDECAR_REQUIRE_DUAL_NODE=1
Environment=BDAG_FASTARTIFACT_SIDECAR_MAX_SEED_LAG=10000
Environment=BDAG_FASTARTIFACT_SIDECAR_MAX_ARCHIVE_AGE_SECONDS=7200
Environment=BDAG_FASTSNAP_REQUIRE_EXPORT_BACKEND_FRESH=1
Environment=BDAG_FASTSNAP_MAX_EXPORT_BACKEND_LAG=1000
EnvironmentFile=-%h/.config/bdag-fastartifact-sidecar.env
Nice=19
IOSchedulingClass=idle
CPUWeight=10
IOWeight=10
ExecStart=/usr/bin/env bash -lc 'exec python3 "${BDAG_PROJECT_ROOT:?set BDAG_PROJECT_ROOT in ~/.config/bdag-fastartifact-sidecar.env}/ops/fastartifact_sidecar.py"'
