[Unit]
Description=BlockDAG hourly chain snapshot
After=bdag-watchdog.service bdag-dashboard.service default.target

[Service]
Type=oneshot
WorkingDirectory=/home/jeremy/blockdag-asic-pool
Environment=BDAG_PROJECT_ROOT=/home/jeremy/blockdag-asic-pool
EnvironmentFile=-/home/jeremy/blockdag-asic-pool/ops/runtime/ops.env
Nice=19
IOSchedulingClass=idle
CPUWeight=10
IOWeight=10
ExecStart=/home/jeremy/blockdag-asic-pool/ops/hourly-chain-snapshot.sh
