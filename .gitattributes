# Git LFS configuration for Blockdag Pool-Stack snapshots
# Large binary files that should be tracked by LFS instead of regular git
# Snapshot files (can be several GB)
*.bdsnap filter=lfs diff=lfs merge=lfs -text
# Chunks under 2 GiB each (for LFS servers with a 2GB object limit)
snapshots/lfs-parts/* filter=lfs diff=lfs merge=lfs -text
