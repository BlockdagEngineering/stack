#!/usr/bin/env python3
"""Host entrypoint for the shared BlockDAG node child guard.

This wrapper intentionally contains no node repair logic. It delegates to
ops/node_child_guard.py so host appliance and runtime timers share the same
automation-control gate. Static invariant references:
DEFAULT_NODE_CHILD_GUARD_NODE = "node"; blockdag-node.
"""

from __future__ import annotations

import os
from pathlib import Path
import sys


def main() -> int:
    project_root = Path(os.environ.get("BDAG_PROJECT_ROOT", Path.cwd())).expanduser()
    script = project_root / "ops" / "node_child_guard.py"
    if not script.exists():
        print(f"missing shared node child guard: {script}", file=sys.stderr)
        return 1
    os.execv(sys.executable, [sys.executable, str(script), *sys.argv[1:]])
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
