# Pool-Stack Docker Compose environment.
# Copy to .env and edit before running `make build`.

# ---------------------------------------------------------------------------
# Build mode
# ---------------------------------------------------------------------------
# DEV=true  -> dockerfile-dev      (builds from local clones in ../)
# DEV=false -> dockerfile-release  (clones blockdag-corechain + asic-pool +
#                                   pool-stack via git, mirrors pool-stack
#                                   .github/workflows/build.yml)
DEV=true

# Required when DEV=false to reach the private repos. Use a PAT with
# Contents: Read on BlockdagEngineering/blockdag-corechain and
# BlockdagEngineering/asic-pool. Leave empty if your network already has
# anonymous read access (rare for these private repos).
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Optional snapshot import when building the node image (local .bdsnap only).
# Path is relative to BUILD_CONTEXT: parent dir when DEV=true (make build), or
# this repo when DEV=false. Empty SNAPSHOT_PATH uses a tiny placeholder (no import).
# Example (dev): blockdag-corechain/snapshot/snapshot.bdsnap
# ---------------------------------------------------------------------------
SNAPSHOT_PATH=

# ---------------------------------------------------------------------------
# Network / port mapping
# ---------------------------------------------------------------------------
NETWORK=mainnet
P2P_PORT=8150
BDAG_RPC_PORT=38131
EVM_HTTP_PORT=18545
EVM_WS_PORT=18546
NODE_METRICS_PORT=6060
POOL_BIND_PORT=3334
POOL_API_PORT=8080
EXPORTER_PORT=9198
NETDATA_PORT=19999

# ---------------------------------------------------------------------------
# Node RPC auth (must match config/node.conf.example rpcuser / rpcpass)
# ---------------------------------------------------------------------------
NODE_RPC_USER=test
NODE_RPC_PASS=test

# ---------------------------------------------------------------------------
# Postgres (used by the pool service via PG_URL)
# ---------------------------------------------------------------------------
POSTGRES_USER=bdag_pool
POSTGRES_DB=bdagpool
# Set a strong secret. Example: openssl rand -hex 32
POSTGRES_PASSWORD=change_me_to_a_strong_secret

# ---------------------------------------------------------------------------
# Optional CPU miner (profile `miner`): set mining address / pool in
# config/miner.env — copy from config/miner.env.example
# ---------------------------------------------------------------------------
