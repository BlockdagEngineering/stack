DOCKERFILE=dockerfile
DOCKER_PLATFORM=linux/amd64
# Optional overrides for dockerfile-dev named build contexts.
BLOCKDAG_CORECHAIN_CONTEXT=../blockdag-corechain
POOL_SRC_CONTEXT=../pool
# CPU_MINER_SRC_CONTEXT=../cpu-miner
DASHBOARD_SRC_CONTEXT=../dashboard
# Paths are relative to tarball root (same directory as docker-compose.yml).
# To import a snapshot during build, place latest.bdsnap in the payload root and
# set SNAPSHOT_PATH=./latest.bdsnap. The default marker means "build without a
# baked-in snapshot."
SNAPSHOT_PATH=docker/no-snapshot.marker
# SNAPSHOT_PATH=docker/latest.bdsnap

# Optional compose services:
#   blank -> base stack only
#   miner -> include CPU miner service (requires DOCKERFILE=dockerfile-dev)
# COMPOSE_PROFILES=miner

# Canonical dashboard/control-plane repository. Release builds always use the
# develop branch. If the repository is private in your environment, export
# GITHUB_TOKEN before running `docker compose build`.
DASHBOARD_REPO=https://github.com/BlockdagEngineering/dashboard.git
BDAG_DASHBOARD_REQUIRE_TOKEN=auto

P2P_PORT=8150
BDAG_RPC_PORT=38131
EVM_HTTP_PORT=18545
EVM_WS_PORT=18546
NODE_METRICS_PORT=6060
POOL_BIND_PORT=3334
POOL_API_PORT=9090

# NODE_DATA_DIR=./node-data

# Required for any pool/miner deployment. Do not use the zero address.
# POOL_COINBASE_ADDRESS may be set separately when it must differ from the
# displayed miner/pool identity; otherwise set MINING_POOL_ADDRESS only.
MINING_POOL_ADDRESS=0xEd5e2dD1377aBe28907673cdEa8c2c04Fb715dcd
POOL_COINBASE_ADDRESS=

# Storage placement for constrained mining appliances. Release installers keep
# growing node chain data on capacity storage, then move frequent small writes
# such as Postgres and dashboard/runtime state to internal storage when it has
# enough free space.
BDAG_STORAGE_PROFILE=auto
BDAG_CHAIN_DATA_DIR=./data
BDAG_DATA_DIR=./data
BDAG_NODE1_DATA_DIR=./data/node1
BDAG_POSTGRES_DATA_DIR=./data/postgres
BDAG_RUNTIME_DIR=./ops/runtime
BDAG_STORAGE_MIN_CHAIN_FREE_GIB=50
BDAG_STORAGE_MIN_RUNTIME_FREE_GIB=4

# Ephemeral scratch policy. Small temporary files belong on RAM-backed tmpfs so
# they do not add avoidable writes to the USB chain device. Large snapshot and
# chain staging must stay on capacity storage unless explicitly sized.
BDAG_EPHEMERAL_TMPFS_ENABLED=1
BDAG_EPHEMERAL_DIR=/run/bdag-pool
BDAG_HOST_TMPDIR=/run/bdag-pool/tmp
BDAG_CONTAINER_TMPFS_SIZE=128m
BDAG_NODE_TMPFS_SIZE=512m
BDAG_NODE_SHM_SIZE=512m
BDAG_BUILD_TMPDIR=./.build-tmp
BDAG_BUILD_CACHE_WARN_GIB=4
BDAG_ROOT_FREE_WARN_GIB=6
BDAG_ROOT_FREE_FAIL_GIB=2

# Single P2P host port used by Docker publishing, firewall, and local peer
# advertisement.
BDAG_P2P_PROTOCOLS=tcp

# Standard mining-host performance defaults. The release topology has one
# production node with a direct pool-to-node RPC path.
BDAG_NODE_CACHE_MB=2048
BDAG_EVM_CACHE_MB=2048
BDAG_NODE_CACHE_DATABASE_PERCENT=70
BDAG_NODE_OBSOLETE_HEIGHT=20
BDAG_BLOCK_READ_AHEAD_KB=1024
BDAG_BLOCK_NR_REQUESTS=256
POOL_RPC_BACKENDS=

# Enables localhost/private-network pool runtime admin endpoints. Keep the pool
# metrics/admin port bound to localhost on public hosts.
POOL_RUNTIME_ADMIN_ENABLED=false
METRICS_ADDR=0.0.0.0:9090

# Host network discovery is only for choosing this node's advertised P2P address.
# Peer candidates should be complete P2P multiaddrs.
BDAG_NETWORK_TOPOLOGY=auto
BDAG_DETECTED_NETWORK_TOPOLOGY=
BDAG_ASIC_LAN_INTERFACE=eth0
BDAG_ASIC_LAN_CIDRS=
BDAG_P2P_ADVERTISE_IP=
BDAG_P2P_INTERFACE=
EXTRA_PEER_ADDRESSES=

# When enabled by installer/watchdog for attached ASICs, this must include
# --allowminingwhennearlysynced, --allowsubmitwhennotsynced, --miner,
# --miningaddr=<non-zero wallet>, and --maxinbound=1 on constrained USB/router hosts.
BDAG_NODE_MINING_ARGS=
BDAG_NODE_CHAIN_RPC_TIMEOUT=8.0
BDAG_NODE_CHAIN_RPC_RETRIES=2
BDAG_POOL_RPC_REFUSED_WARN_SECONDS=120
BDAG_HOST_PRESSURE_IOWAIT_WARN_PERCENT=25
BDAG_HOST_PRESSURE_IOWAIT_WARN_SAMPLES=3
BDAG_HOST_PRESSURE_HISTORY_SAMPLES=6
BDAG_SHARED_STATUS_CACHE_ENABLED=1
BDAG_SHARED_STATUS_CACHE_SECONDS=3.0
BDAG_STATUS_PAYLOAD_STALE_AFTER_SECONDS=120
BDAG_HOST_PROFILE=auto
BDAG_ADAPTIVE_CONCURRENCY_ENABLED=1
BDAG_ADAPTIVE_IOWAIT_WARN_PERCENT=25
BDAG_ADAPTIVE_IO_SOME_AVG10_WARN=20.0
BDAG_ADAPTIVE_CPU_SOME_AVG10_WARN=80.0
BDAG_ADAPTIVE_CHAIN_RPC_WARN_MS=1000
BDAG_STATUS_SAMPLER_ENABLED=1
BDAG_STATUS_SAMPLER_INTERVAL_SECONDS=10
BDAG_STATUS_SAMPLER_MAX_AGE_SECONDS=120
BDAG_DASHBOARD_DIRECT_STATUS_FALLBACK=0
BDAG_DASHBOARD_STATUS_CACHE_SECONDS=120
BDAG_DASHBOARD_SAMPLER_CACHE_SECONDS=120
BDAG_DASHBOARD_STATUS_SAMPLE_WAIT_SECONDS=60
BDAG_WATCHDOG_EARNINGS_SNAPSHOT_INTERVAL_SECONDS=60
BDAG_STATUS_SAMPLER_EARNINGS_SNAPSHOT_INTERVAL_SECONDS=60
BDAG_DASHBOARD_EARNINGS_SAMPLER_INTERVAL_SECONDS=60
BDAG_DASHBOARD_GLOBAL_SAMPLER_INTERVAL_SECONDS=60
BDAG_GLOBAL_RPC_WORKERS=24
BDAG_GLOBAL_BLOCK_WINDOW=128
BDAG_GLOBAL_CACHE_MAX_TIP_LAG_BLOCKS=30
# Optional native mining RPC list for Global chain-production stats.
# EVM RPC variables are wallet/balance sources only and must not drive Global mining attribution.
BDAG_GLOBAL_CHAIN_RPC_URLS=
BDAG_MINER_SCAN_WORKERS=64
BDAG_MINER_HASHRATE_PROBE_WORKERS=8
BDAG_BACKGROUND_MAINTENANCE_BACKOFF_ENABLED=1
BDAG_BACKGROUND_MAINTENANCE_SYNC_BACKOFF_BLOCKS=0
BDAG_BACKGROUND_MAINTENANCE_IOWAIT_WARN_PERCENT=25
BDAG_BACKGROUND_MAINTENANCE_IO_SOME_AVG10_WARN=20.0
BDAG_BACKGROUND_MAINTENANCE_CPU_SOME_AVG10_WARN=80.0
BDAG_BACKGROUND_MAINTENANCE_CHAIN_RPC_WARN_MS=1000
BDAG_GLOBAL_HISTORY_COMPACT_MULTIPLIER=2
BDAG_ENTRYPOINT_CHOWN_MODE=needed
BDAG_NODEWORKER_LIVENESS_TIMEOUT=5m

# P2P bootstrap and coordinator defaults.
BOOTSTRAP_PEER_ADDRESSES=/ip4/13.57.132.47/tcp/8150/p2p/16Uiu2HAmDynYpWjWmgVGf9qVWvDdLnJ3ybVgDmFexizR4zMereus
SYNC_SOURCE_NODE=0
BDAG_SYNC_COORDINATOR_FAST_RESTART_COOLDOWN_SECONDS=900
BDAG_SYNC_COORDINATOR_RESTART_ON_STALE_IMPORT=1

NODE_RPC_USER=test
NODE_RPC_PASS=test
NODE_RPC_URLS=http://node:38131
# Optional block-candidate submit override. Leave blank to use NODE_RPC_URLS.
# Named entries are allowed: local=http://node:38131
POOL_SUBMIT_RPC_URLS=

# Extra node flags.
NODE_ARGS_APPEND=

POSTGRES_USER=bdag_pool
POSTGRES_DB=bdagpool
POSTGRES_PASSWORD=change_me_to_a_strong_secret

# ---------------------------------------------------------------------------
# Mining pool — passed into `pool` container (asic-pool env)
# ---------------------------------------------------------------------------
POOL_BIND_ADDR=0.0.0.0:3334
PPLNS_N_WORK=1000
POOL_FEE_PERCENTAGE=1.0
POOL_BLOCK_MATURITY=10
POOL_PAYOUT_MATURITY=4096

# CPU miner (only used when COMPOSE_PROFILES includes "miner").
MINER_POOL_URL=stratum+tcp://pool:3334
MINER_POOL_PASS=x
MINER_WORKERS=1




# Live-tested block-candidate policy from the 2026-05-28 tip-overdue A/B tests.
# 800ms produced the best accepted-block rate around the one-second target
# block interval while reducing late tip-overdue submissions.
POOL_TEMPLATE_TTL_REFRESH_MS=500
POOL_SUBMIT_STALE_BLOCK_CANDIDATES=false
POOL_MAX_BLOCK_CANDIDATE_JOB_AGE_MS=2500
POOL_SUBMIT_BLOCK_HEADER_V2_ENABLED=true
POOL_STALE_RACE_REJECT_WINDOW_SECONDS=10
POOL_STALE_RACE_CLIENT_RESEND_THRESHOLD=1
POOL_STALE_RACE_RECOVERY_COOLDOWN_SECONDS=1
POOL_EXPIRED_JOB_CLIENT_RECONNECT_THRESHOLD=3
POOL_EXPIRED_JOB_CLIENT_RECONNECT_WINDOW_SECONDS=120
POOL_EXPIRED_JOB_CLIENT_RECONNECT_COOLDOWN_SECONDS=60
POOL_ALLOW_MULTIPLE_BLOCK_CANDIDATES_PER_JOB=true
POOL_PREEMPTIVE_BLOCK_CANDIDATE_REFRESH_ENABLED=true
