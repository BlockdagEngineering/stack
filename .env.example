# Pool-Stack Docker Compose — pool-only (no cpu-miner image or profile).
#
# Copy:  cp .env.pool.example .env
#
# - **pool-v* tarball:** keep "Release" below (BUILD_CONTEXT=., dockerfile-pool-release).
# - **Git clone (dockerfile-dev, no miner):** use the Git dev block.

# ============================================================================
# Git dev — local compile, no miner profile
#   BUILD_CONTEXT=..
#   DOCKERFILE=pool-stack-docker/dockerfile-dev
#   SNAPSHOT_PATH=
#   COMPOSE_PROFILES=        (empty — dockerfile-pool-release has no miner target)
# ============================================================================

# ----------------------------------------------------------------------------
# Release (prebuilt ./bin — pool-v* tarball)
# ----------------------------------------------------------------------------

COMPOSE_PROFILES=

BUILD_CONTEXT=.
DOCKERFILE=dockerfile
SNAPSHOT_PATH=docker/no-snapshot.marker

NETWORK=mainnet
P2P_PORT=8150
BDAG_RPC_PORT=38131
EVM_HTTP_PORT=18545
EVM_WS_PORT=18546
NODE_METRICS_PORT=6060
POOL_BIND_PORT=3334
POOL_API_PORT=8080

NODE_RPC_USER=test
NODE_RPC_PASS=test

POSTGRES_USER=bdag_pool
POSTGRES_DB=bdagpool
POSTGRES_PASSWORD=change_me_to_a_strong_secret

# ---------------------------------------------------------------------------
# Mining pool — passed into `pool` container (asic-pool env)
# ---------------------------------------------------------------------------
POOL_BIND_ADDR=0.0.0.0:3334
PPLNS_N_WORK=1000
POOL_FEE_PERCENTAGE=1.0
POOL_BLOCK_MATURITY=10
POOL_PAYOUT_MATURITY=4096
