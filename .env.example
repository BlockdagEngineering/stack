BUILD_CONTEXT=.
DOCKERFILE=dockerfile
# Paths are relative to tarball root (same directory as docker-compose.yml).
# SNAPSHOT_PATH=docker/no-snapshot.marker
# To import a snapshot during build: place a .bdsnap in the tarball dir 
SNAPSHOT_PATH=./latest.bdsnap

NETWORK=mainnet
P2P_PORT=8150
BDAG_RPC_PORT=38131
EVM_HTTP_PORT=18545
EVM_WS_PORT=18546
NODE_METRICS_PORT=6060
POOL_BIND_PORT=3334
POOL_API_PORT=8080

NODE_RPC_USER=test
NODE_RPC_PASS=test

POSTGRES_USER=bdag_pool
POSTGRES_DB=bdagpool
POSTGRES_PASSWORD=change_me_to_a_strong_secret

# ---------------------------------------------------------------------------
# Mining pool — passed into `pool` container (asic-pool env)
# ---------------------------------------------------------------------------
POOL_BIND_ADDR=0.0.0.0:3334
PPLNS_N_WORK=1000
POOL_FEE_PERCENTAGE=1.0
POOL_BLOCK_MATURITY=10
POOL_PAYOUT_MATURITY=4096
