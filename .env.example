# Pool-Stack Docker Compose environment.
# Copy to .env and edit before running `make build`.

# ---------------------------------------------------------------------------
# Build mode
# ---------------------------------------------------------------------------
# DEV=true  — dockerfile-dev (compile from local clones under ../)
# DEV=false — use release Dockerfiles + ./bin (see .env.cpu.example / .env.pool.example
#             for unpacked tarball: BUILD_CONTEXT=. , no upstream git in image build)
DEV=true

# Only for automation that clones private repos to produce bin/ (not read by release Dockerfiles).
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Optional snapshot import when building the node image (local .bdsnap only).
# Path is relative to BUILD_CONTEXT:
#   Git dev (BUILD_CONTEXT=..): e.g. pool-stack-docker/docker/no-snapshot.marker or
#   blockdag-corechain/snapshot/foo.bdsnap
#   Release tarball (BUILD_CONTEXT=.): e.g. docker/no-snapshot.marker
#
# Leave unset, blank, or comment out for NO import — compose defaults to
# pool-stack-docker/docker/no-snapshot.marker (tiny file < 1KB → snap step skips).
# ---------------------------------------------------------------------------
SNAPSHOT_PATH=

# ---------------------------------------------------------------------------
# Network / port mapping
# ---------------------------------------------------------------------------
NETWORK=mainnet
P2P_PORT=8150
BDAG_RPC_PORT=38131
EVM_HTTP_PORT=18545
EVM_WS_PORT=18546
NODE_METRICS_PORT=6060
POOL_BIND_PORT=3334
POOL_API_PORT=8080
EXPORTER_PORT=9198
NETDATA_PORT=19999

# ---------------------------------------------------------------------------
# Node RPC auth (must match node.conf.example rpcuser / rpcpass after you copy to node.conf)
# ---------------------------------------------------------------------------
NODE_RPC_USER=test
NODE_RPC_PASS=test

# ---------------------------------------------------------------------------
# Postgres (used by the pool service via PG_URL)
# ---------------------------------------------------------------------------
POSTGRES_USER=bdag_pool
POSTGRES_DB=bdagpool
# Set a strong secret. Example: openssl rand -hex 32
POSTGRES_PASSWORD=change_me_to_a_strong_secret

# ---------------------------------------------------------------------------
# Mining pool (asic-pool) — passed into the `pool` container; see asic-pool/cmd/pool/main.go
# NODE_RPC_URL and PG_URL are set in docker-compose.yml to use service names.
# ---------------------------------------------------------------------------
POOL_BIND_ADDR=0.0.0.0:3334
PPLNS_N_WORK=1000
POOL_FEE_PERCENTAGE=1.0
POOL_BLOCK_MATURITY=10
POOL_PAYOUT_MATURITY=4096
# WALLET_RPC_URL=
# POOL_PRIVATE_KEY=
# METRICS_ADDR=
# POOL_INSTANCE_ID=

# ---------------------------------------------------------------------------
# Compose profiles: `miner` enables the CPU miner service (built from dockerfile-dev).
# Default ON for Git dev — set empty for pool-only release (dockerfile-pool-release has no miner target).
# ---------------------------------------------------------------------------
COMPOSE_PROFILES=miner

# ---------------------------------------------------------------------------
# CPU miner (`miner` service; requires COMPOSE_PROFILES=miner or --profile miner).
# Maps to POOL_URL / POOL_USER / POOL_PASS / WORKERS inside the container.
# ---------------------------------------------------------------------------
# MINER_POOL_URL=stratum+tcp://pool:3334
# MINER_POOL_USER=0x0000000000000000000000000000000000000000
# MINER_POOL_PASS=x
# MINER_WORKERS=1
