BUILD_CONTEXT=.
DOCKERFILE=dockerfile
DOCKER_PLATFORM=linux/amd64
# Paths are relative to tarball root (same directory as docker-compose.yml).
# SNAPSHOT_PATH=docker/no-snapshot.marker
# To import a snapshot during build: place a .bdsnap in the tarball dir 
SNAPSHOT_PATH=./latest.bdsnap

NETWORK=mainnet
P2P_PORT=8150
BDAG_RPC_PORT=38131
EVM_HTTP_PORT=18545
EVM_WS_PORT=18546
NODE_METRICS_PORT=6060
POOL_BIND_PORT=3334
POOL_API_PORT=9090

# P2P firewall/discovery helper defaults. The standalone compose uses 8150;
# two-node release packages commonly use 8151 and 8152.
BDAG_P2P_PORTS=8150,8151,8152
BDAG_P2P_PROTOCOLS=tcp

# Standard mining-host performance defaults. BDAG_CAPABILITY_PROFILE=auto lets
# install/preflight/tuning select safer values from CPU, RAM, network topology,
# and active chain storage rather than from architecture alone. Multi-node
# release packages should keep dual nodes online for redundancy, but use
# active/passive template routing for ASIC work instead of active/active
# template fan-in.
BDAG_CAPABILITY_PROFILE=auto
BDAG_CACHE_POLICY=auto
BDAG_CHAIN_DATA_PATHS=./data/node1,./data/node2,./data/postgres
BDAG_NODE_CACHE_MB=2048
BDAG_EVM_CACHE_MB=2048
BDAG_NODE_CACHE_DATABASE_PERCENT=70
BDAG_NODE_CACHE_SNAPSHOT_PERCENT=35
BDAG_NODE_BD_CACHE_SIZE=8192
BDAG_NODE_DAG_CACHE_SIZE=8192
BDAG_EVM_CACHE_DATABASE_PERCENT=80
BDAG_EVM_CACHE_SNAPSHOT_PERCENT=1
BDAG_NODE_GOMEMLIMIT=off
BDAG_NODE_GOGC=100
BDAG_POOL_GOMEMLIMIT=512MiB
BDAG_BLOCK_READ_AHEAD_KB=1024
BDAG_BLOCK_NR_REQUESTS=256
BDAG_VM_TUNING_ENABLED=1
BDAG_VM_SWAPPINESS=10
BDAG_VM_VFS_CACHE_PRESSURE=50
BDAG_VM_DIRTY_BACKGROUND_BYTES=67108864
BDAG_VM_DIRTY_BYTES=268435456
BDAG_FSTRIM_ENABLED=1
POOL_RPC_ROUTER_TEMPLATE_LANE_MODE=active-passive
POOL_RPC_ROUTER_ENABLED=false
POOL_RPC_ROUTER_NODE_HEALTH_ENABLED=true
POOL_RPC_BACKENDS=
POOL_DUPLICATE_SAFE_MULTI_BACKEND_SUBMIT=true
POOL_RPC_ROUTER_MIN_HEALTHY_SECONDS=10
POOL_RPC_ROUTER_SWITCH_COOLDOWN_SECONDS=20
POOL_RPC_ROUTER_TEMPLATE_MAX_AGE_SECONDS=5
POOL_RPC_ROUTER_RECOVERY_PROBE_SECONDS=15
POOL_RPC_ROUTER_NODE_HEALTH_PROBE_SECONDS=1
POOL_RPC_ROUTER_NODE_HEALTH_MAX_AGE_SECONDS=3
POOL_RPC_ROUTER_NODE_HEALTH_UNREADY_THRESHOLD=1
POOL_RPC_ROUTER_NODE_HEALTH_ERROR_THRESHOLD=2
POOL_RPC_ROUTER_NODE_HEALTH_FRESH_TEMPLATE_GRACE_SECONDS=5

# Enables localhost/private-network pool runtime admin endpoints. Required for
# controlled FastSnap maintenance drains and guarded adaptive pool tuning. Keep
# the pool metrics/admin port bound to localhost on public hosts.
POOL_RUNTIME_ADMIN_ENABLED=true
METRICS_ADDR=0.0.0.0:9090

# Guarded pool adaptive optimizer. Keep BDAG_CAPABILITY_PROFILE=auto so
# install/preflight/portable runners can tune these defaults for constrained
# flash, USB SSD, NVMe, Linux, macOS, and Windows Docker hosts.
BDAG_POOL_OPTIMIZER_METRICS_URL=http://127.0.0.1:9092/metrics
BDAG_POOL_OPTIMIZER_ADMIN_URL=http://127.0.0.1:9092
BDAG_POOL_OPTIMIZER_DASHBOARD_STATUS_URL=http://127.0.0.1:8088/api/status
BDAG_POOL_OPTIMIZER_USE_CAPABILITY_DEFAULTS=1
BDAG_POOL_OPTIMIZER_ITERATIONS=1
BDAG_POOL_OPTIMIZER_WINDOW_SECONDS=900
BDAG_POOL_OPTIMIZER_SAMPLE_INTERVAL_SECONDS=30
BDAG_POOL_OPTIMIZER_CHANGE_COOLDOWN_SECONDS=1800
BDAG_POOL_OPTIMIZER_SAFE_TEMPLATE_TTL_MS=500
BDAG_POOL_OPTIMIZER_SAFE_BLOCK_CANDIDATE_JOB_AGE_MS=800
BDAG_POOL_OPTIMIZER_SAFE_VARDIFF_TARGET_SHARE_SECONDS=3.0
BDAG_POOL_OPTIMIZER_SAFE_VARDIFF_WINDOW_SECONDS=120
BDAG_POOL_OPTIMIZER_TIMER_ON_BOOT_SEC=10m
BDAG_POOL_OPTIMIZER_TIMER_ON_UNIT_ACTIVE_SEC=30m
BDAG_POOL_OPTIMIZER_TIMER_RANDOMIZED_DELAY_SEC=2m
BDAG_POOL_OPTIMIZER_RUNNER_INTERVAL_SECONDS=1800

# Optional static peers discovered on operator LAN/VPN networks.
BDAG_NETWORK_TOPOLOGY=auto
BDAG_DETECTED_NETWORK_TOPOLOGY=
BDAG_ASIC_LAN_INTERFACE=eth0
BDAG_ASIC_LAN_CIDRS=192.168.50.0/24
BDAG_ALLOW_ASIC_LAN_P2P=0
BDAG_P2P_ADVERTISE_IP=
BDAG_P2P_INTERFACE=
BDAG_P2P_LAN_PEERS=
BDAG_P2P_VPN_PEERS=
BDAG_P2P_PUBLIC_PEERS=
LAN_PEER_ADDRESSES=
VPN_PEER_ADDRESSES=
ZEROTIER_PEER_ADDRESSES=
EXTRA_PEER_ADDRESSES=

# Pi5 RC runtime mode. Single-node mode is the safe default on constrained USB
# power. No-miner installs must stay sync-only until mining is explicitly
# enabled for real attached miners.
BDAG_NODE_MODE=single
COMPOSE_PROFILES=
BDAG_NODE_SERVICES=bdag-miner-node-2
BDAG_STACK_SERVICES=pool-db,bdag-miner-node-2,rpc-failover,asic-pool
BDAG_ENABLE_NODE_MINING=0
BDAG_NODE_MODULES=Blockdag
BDAG_NODE_MINING_ARGS=
BDAG_NODE_CHAIN_RPC_TIMEOUT=8.0
BDAG_NODE_CHAIN_RPC_RETRIES=2
BDAG_POOL_RPC_REFUSED_WARN_SECONDS=120
BDAG_HOST_PRESSURE_IOWAIT_WARN_PERCENT=25
BDAG_HOST_PRESSURE_IOWAIT_WARN_SAMPLES=3
BDAG_HOST_PRESSURE_HISTORY_SAMPLES=6
BDAG_SHARED_STATUS_CACHE_ENABLED=1
BDAG_SHARED_STATUS_CACHE_SECONDS=3.0
BDAG_HOST_PROFILE=auto
BDAG_ADAPTIVE_CONCURRENCY_ENABLED=1
BDAG_ADAPTIVE_IOWAIT_WARN_PERCENT=25
BDAG_ADAPTIVE_IO_SOME_AVG10_WARN=20.0
BDAG_ADAPTIVE_CPU_SOME_AVG10_WARN=80.0
BDAG_ADAPTIVE_CHAIN_RPC_WARN_MS=1000
BDAG_STATUS_SAMPLER_ENABLED=1
BDAG_STATUS_SAMPLER_INTERVAL_SECONDS=10
BDAG_STATUS_SAMPLER_MAX_AGE_SECONDS=12
BDAG_GLOBAL_RPC_WORKERS=24
BDAG_MINER_SCAN_WORKERS=64
BDAG_MINER_HASHRATE_PROBE_WORKERS=8
BDAG_BACKGROUND_MAINTENANCE_BACKOFF_ENABLED=1
BDAG_BACKGROUND_MAINTENANCE_SYNC_BACKOFF_BLOCKS=0
BDAG_BACKGROUND_MAINTENANCE_IOWAIT_WARN_PERCENT=25
BDAG_BACKGROUND_MAINTENANCE_IO_SOME_AVG10_WARN=20.0
BDAG_BACKGROUND_MAINTENANCE_CPU_SOME_AVG10_WARN=80.0
BDAG_BACKGROUND_MAINTENANCE_CHAIN_RPC_WARN_MS=1000
BDAG_GLOBAL_HISTORY_COMPACT_MULTIPLIER=2
BDAG_ENTRYPOINT_CHOWN_MODE=needed

# Optional pre-start P2P snapshot bootstrap. When the node datadir is empty,
# the node image uses ordinary trusted/addpeer candidates for FastSnap V2 first,
# imports the verified snapshot, then normal FastSync catches the remaining tail.
BDAG_FASTSNAP_ENABLED=1
BDAG_FASTSNAP_REQUIRED=0
BDAG_FASTSNAP_PEERS=
BDAG_FASTSNAP_MIN_TIP=0
BDAG_FASTSNAP_TIMEOUT=90s
BDAG_FASTSNAP_ARTIFACT_V2=1
# Prefer Fast Artifact Sync V2 directory artifacts when a peer offers them.
# This avoids building/importing a temporary .bdsnap archive. Archive V2 and
# legacy snapshot RPC remain fallback paths when the peer only supports them.
BDAG_FASTSNAP_DIRECTORY_MODE=1
BDAG_FASTSNAP_DIRECTORY_STAGING=
BDAG_FASTSNAP_DIRECTORY_REPLACE_EXISTING=1
BDAG_FASTSNAP_DIRECTORY_MOVE_STAGING=1
BDAG_FASTSNAP_ALLOW_UNSIGNED=0
BDAG_FASTSNAP_PARALLELISM=4
BDAG_FASTSNAP_LEDGER=

# Public FastSnap seed serving is a default release behaviour for dual-node
# mining hosts. The low-priority bdag-fastsnap-seed timer refreshes a verified
# snapshot.bdsnap and hardlinks one archive into both node datadirs for P2P
# serving. Keep the freshness gate enabled for public seeds.
BDAG_FASTSNAP_SEED_TIMER_ENABLED=1
BDAG_FASTSNAP_REQUIRE_EXPORT_BACKEND_FRESH=1
BDAG_FASTSNAP_MAX_EXPORT_BACKEND_LAG=1000

# Optional Fast Artifact Sync V2 directory hot-stage serving. Set these only on
# nodes that maintain a verified directory artifact mirror. The manifest path is
# allowed to be a sidecar outside the directory to avoid copying control files
# into a future install target.
BDAG_FASTSYNC_ARTIFACT_DIRECTORY=
BDAG_FASTSYNC_ARTIFACT_MANIFEST=

# FastSync candidate order for new/empty nodes and startup peers. Entries must
# be complete multiaddrs with peer IDs. The default keeps local LAN peers first,
# private/VPN peers second, and public internet seeds last.
BDAG_FASTSYNC_PEER_ORDERING=tiered-latency
BDAG_FASTSYNC_APPEND_ADDPEERS=1
BDAG_NO_FASTSYNC_SERVE=auto
BDAG_FASTARTIFACTSYNC_ENABLED=1
BDAG_FASTSYNC_LAN_PREFIXES=
BDAG_FASTSYNC_LAN_PEERS=
BDAG_FASTSYNC_VPN_PEERS=
BDAG_FASTSYNC_PUBLIC_PEERS=
BDAG_FASTSYNC_PEERS=
BDAG_FASTSYNC_PREPROCESS_WORKERS=1
BDAG_SYNC_COORDINATOR_ACCELERATE_FASTSYNC=1
BDAG_SYNC_COORDINATOR_FAST_RESTART_COOLDOWN_SECONDS=900
BDAG_SYNC_COORDINATOR_RESTART_ON_MISSING_FASTARTIFACT=1
BDAG_SYNC_COORDINATOR_RESTART_ON_STALE_IMPORT=1

NODE_RPC_USER=test
NODE_RPC_PASS=test
NODE_RPC_URLS=http://node:38131
# Optional block-candidate submit fanout. Leave blank to use NODE_RPC_URLS.
# Named entries are allowed: node1=http://node:38131,node2=http://node2:38131
POOL_SUBMIT_RPC_URLS=

# ---------------------------------------------------------------------------
# Fast Artifact Sync V2
# ---------------------------------------------------------------------------
NODE_ARGS_APPEND=--fastartifactsync
BDAG_FASTSYNC_SNAPSHOT_PATH=
BDAG_FASTSYNC_ARTIFACT_SIGNING_KEY_ID=
BDAG_FASTSYNC_ARTIFACT_SIGNING_KEY_HEX=
BDAG_FASTSYNC_ARTIFACT_MANIFEST_TTL=24h
BDAG_FASTSNAP_ENABLED=1
BDAG_FASTSNAP_REQUIRED=0
BDAG_FASTSNAP_PEERS_FILE=/etc/bdagStack/node.conf
BDAG_FASTSNAP_AUTO_MAX_PEERS=3
BDAG_FASTSNAP_LEGACY_FALLBACK=0
BDAG_FASTSNAP_NETWORK=mainnet
BDAG_FASTSNAP_PEERS=
BDAG_FASTSNAP_MIN_TIP=0
BDAG_FASTSNAP_TIMEOUT=300s
BDAG_FASTSNAP_RETRIES=5
BDAG_FASTSNAP_RETRY_DELAY=10s
BDAG_FASTSNAP_TRUSTED_SIGNERS=
BDAG_FASTSNAP_ALLOW_UNSIGNED=0
BDAG_FASTSNAP_KEEP_ARCHIVE=0

# Hot staged snapshot node/export defaults. Set BDAG_HOTSNAP_ENABLED=0 to
# disable the automatic refresher without disabling normal node operation.
SNAPSHOT_NODE_ARGS_APPEND=--fastartifactsync
SNAPSHOT_BDAG_FASTSNAP_ENABLED=1
SNAPSHOT_BDAG_FASTSNAP_REQUIRED=0
SNAPSHOT_P2P_PORT=9150
SNAPSHOT_BDAG_RPC_PORT=48131
SNAPSHOT_EVM_HTTP_PORT=28545
SNAPSHOT_EVM_WS_PORT=28546
SNAPSHOT_NODE_METRICS_PORT=16060
BDAG_HOTSNAP_ENABLED=1
BDAG_HOTSNAP_INTERVAL=1h
BDAG_HOTSNAP_INITIAL_DELAY=20m
BDAG_HOTSNAP_STOP_TIMEOUT=60
BDAG_HOTSNAP_DATADIR=/var/lib/bdagStack/node/mainnet
BDAG_HOTSNAP_ARCHIVE=/var/lib/bdagStack/node/mainnet/snapshot.bdsnap

POSTGRES_USER=bdag_pool
POSTGRES_DB=bdagpool
POSTGRES_PASSWORD=change_me_to_a_strong_secret

# ---------------------------------------------------------------------------
# Mining pool — passed into `pool` container (asic-pool env)
# ---------------------------------------------------------------------------
POOL_BIND_ADDR=0.0.0.0:3334
PPLNS_N_WORK=1000
POOL_FEE_PERCENTAGE=1.0
POOL_BLOCK_MATURITY=10
POOL_PAYOUT_MATURITY=4096

# Required for any pool/miner deployment. Do not use the zero address.
# POOL_COINBASE_ADDRESS may be set separately when it must differ from the
# displayed miner/pool identity; otherwise set MINING_POOL_ADDRESS only.
MINING_POOL_ADDRESS=
POOL_COINBASE_ADDRESS=

# Block-candidate policy: keep submit work inside the paid-block window.
# Newer template sequence work supersedes jobs after 900ms; a same-template
# TTL refresh starts at half-block timing for the current fast-DAG network.
POOL_TEMPLATE_TTL_REFRESH_MS=500
POOL_SUBMIT_STALE_BLOCK_CANDIDATES=false
POOL_MAX_BLOCK_CANDIDATE_JOB_AGE_MS=800
POOL_MAX_BLOCK_CANDIDATE_SAME_TEMPLATE_AGE_MS=6000
POOL_MAX_BLOCK_CANDIDATE_TEMPLATE_LAG_BLOCKS=16
POOL_SUBMIT_BLOCK_HEADER_V2_ENABLED=true
POOL_STALE_RACE_REJECT_WINDOW_SECONDS=10
POOL_STALE_RACE_CLIENT_RESEND_THRESHOLD=1
POOL_STALE_RACE_RECOVERY_COOLDOWN_SECONDS=1
POOL_ACK_STALE_SHARES=true
POOL_ACK_STALE_SHARE_GRACE_MS=3000
POOL_ALLOW_MULTIPLE_BLOCK_CANDIDATES_PER_JOB=true
POOL_PREEMPTIVE_BLOCK_CANDIDATE_REFRESH_ENABLED=true
POOL_VARDIFF_WINDOW_SECONDS=120
POOL_VARDIFF_TARGET_SHARE_SECONDS=3
POOL_VARDIFF_TOLERANCE_FRACTION=0.5
POOL_VARDIFF_STEP_EXPONENT=0.2
POOL_VARDIFF_FAST_RETARGET_SECONDS=10
