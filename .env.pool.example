# Pool-Stack Docker Compose — pool-only release tarball (pool-v* tags).
# Copy to .env:  cp .env.pool.example .env
#
# Unpacked tarball: images copy ./bin only (dockerfile-pool-release has no miner stage).
# Leave COMPOSE_PROFILES empty — never `miner` (no miner image in this tarball).

GITHUB_TOKEN=

COMPOSE_PROFILES=

DEV=false
BUILD_CONTEXT=.
DOCKERFILE=dockerfile-pool-release
SNAPSHOT_PATH=docker/no-snapshot.marker

NETWORK=mainnet
P2P_PORT=8150
BDAG_RPC_PORT=38131
EVM_HTTP_PORT=18545
EVM_WS_PORT=18546
NODE_METRICS_PORT=6060
POOL_BIND_PORT=3334
POOL_API_PORT=8080
EXPORTER_PORT=9198
NETDATA_PORT=19999

NODE_RPC_USER=test
NODE_RPC_PASS=test

POSTGRES_USER=bdag_pool
POSTGRES_DB=bdagpool
POSTGRES_PASSWORD=change_me_to_a_strong_secret

# ---------------------------------------------------------------------------
# Mining pool — passed into `pool` container (see .env.example)
# ---------------------------------------------------------------------------
POOL_BIND_ADDR=0.0.0.0:3334
PPLNS_N_WORK=1000
POOL_FEE_PERCENTAGE=1.0
POOL_BLOCK_MATURITY=10
POOL_PAYOUT_MATURITY=4096
