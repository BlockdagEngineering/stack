# CPU stratum miner (cpu-miner binary). Copy to miner.env in this directory:
#   cp miner.env.example miner.env
# The compose `miner` service loads config/miner.env when present (optional).
#
# Variable names match cpu-miner/cmd/miner/main.go (POOL_URL, POOL_USER, POOL_PASS, WORKERS).

# Stratum endpoint (use service name `pool` on the Docker network)
POOL_URL=stratum+tcp://pool:3334

# Payout / worker identity (mining address)
POOL_USER=0x0000000000000000000000000000000000000000
POOL_PASS=x

# Parallel mining workers
WORKERS=1
