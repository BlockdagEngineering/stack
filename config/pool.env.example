# Mining pool environment.
# Copy to config/pool.env (next to docker-compose.yml). The pool service loads
# this file via env_file. NODE_RPC_URL and PG_URL are overridden in
# docker-compose.yml to point at the in-network postgres + node service names.

# --- Stratum + API listeners (inside the container) ---
POOL_BIND_ADDR=0.0.0.0:3334
POOL_API_ADDR=0.0.0.0:8080

# --- Node RPC credentials (must match node.conf.example rpcuser / rpcpass) ---
NODE_RPC_USER=test
NODE_RPC_PASS=test

# --- Optional payout signing ---
# WALLET_RPC_URL=http://node:18545
# POOL_PRIVATE_KEY=

# --- PPLNS / fees / maturity (0 = use defaults) ---
PPLNS_N_WORK=1000
POOL_FEE_PERCENTAGE=1.0
POOL_BLOCK_MATURITY=10
POOL_PAYOUT_MATURITY=4096

# Optional metrics + alerting
# METRICS_ADDR=:9090
# POOL_INSTANCE_ID=
# ALERT_WEBHOOK_URL=
